library(tidyr)
cashflows_raw |>
rename("contract_number" = "contract_nr") |> # Make loan id field name consistent
pivot_longer(
starts_with("x20"),
names_to = "cashflow_date",
values_to = "cashflow_amount"
)
cashflows_raw |>
rename("contract_number" = "contract_nr") |> # Make loan id field name consistent
pivot_longer(
starts_with("x20"),
names_to = "cashflow_date",
values_to = "cashflow_amount"
) |>
mutate(
cashflow_date = convert_to_date(.data$cashflow_date)
)
library(tidyr)
format_dates <- function(vec) {
gsub("x", "", vec) |>
as.Date(format = "%Y_%m")
}

library(tidyr)
library(lubridate)
format_dates <- function(vec) {
dates <- gsub("x", "", vec) |>
paste0("_01") |>
as.Date(format = "%Y_%m_%d") |>
ceiling_date(unit = "months")
dates - days(1)
}
cashflows_raw |>
rename("contract_number" = "contract_nr") |> # Make loan id field name consistent
pivot_longer(
starts_with("x20"),
names_to = "cashflow_date",
values_to = "cashflow_amount"
) |>
mutate(
cashflow_date = format_dates(.data$cashflow_date)
)
summary(loans$delay_days_principal)
360 + 180
540+180
summarise(
cashflows,
cumulative_cashflow_amount = sum(cashflow_amount, na.rm = TRUE),
.by = "contract_number"
)
cumulative_cashflow <- summarise(
cashflows,
cumulative_cashflow_amount = sum(cashflow_amount, na.rm = TRUE),
.by = "contract_number"
)
loans |>
left_join(cumulative_cashflow, by = "contract_number") |>
mutate(
days_past_due_bucket = cut(
delay_days_principal,
breaks = c(-Inf, 180, 360, 540, 720, Inf),
labels = c(
"[0, 180)", "[180, 360)", "[360, 540)", "[540, 720)", "720+"
)
)
)
cumulative_cashflow <- summarise(
cashflows,
cumulative_cashflow_amount = sum(cashflow_amount, na.rm = TRUE),
.by = "contract_number"
)
loans |>
left_join(cumulative_cashflow, by = "contract_number") |>
mutate(
days_past_due_bucket = cut(
delay_days_principal,
breaks = c(-Inf, 180, 360, 540, 720, Inf),
labels = c(
"[0, 180)", "[180, 360)", "[360, 540)", "[540, 720)", "720+"
),
right = FALSE # Ensures the buckets are "closed" on the left
)
)
